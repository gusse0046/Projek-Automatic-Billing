            Log::info("Total attachments prepared: " . count($attachments));

// ✅ UPDATED: Booking number FIRST
            $displayNumber = $bookingNumber ?: ($finalBillingDocument ?: $deliveryOrder);
            
            if ($bookingNumber) {
                $subject = "Booking: {$bookingNumber}";
                if ($finalBillingDocument && $finalBillingDocument !== $deliveryOrder) {
                    $subject .= " - Doc {$finalBillingDocument}";
                }
            } else {
                $subject = "Doc {$displayNumber}";
            }
            
