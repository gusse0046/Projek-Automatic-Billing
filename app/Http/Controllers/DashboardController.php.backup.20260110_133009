    /**
     * Get location based on delivery order prefix
     */
    private function getLocationFromDeliveryOrder($deliveryOrder)
    {
        $prefix = substr($deliveryOrder, 0, 3);
        
        switch ($prefix) {
            case '201':
            case '211':  // Surabaya variant (untuk billing 315)
                return 'Surabaya';
                
            case '202':
            case '212':  // Semarang variant (jika ada)
                return 'Semarang';
                
            default:
                \Log::warning("Unknown DO prefix: {$prefix} for delivery: {$deliveryOrder}");
                return 'Unknown';
        }
    }

    /**
     * Check if delivery qualifies as LOCAL (Billing Doc 315 or 316)
     */
    private function isLocalDelivery($billingDocument)
    {
        $prefix = substr($billingDocument, 0, 3);
        return in_array($prefix, ['315', '316']);
    }

    /**
     * Group data by location
     */
    private function groupDataByLocation($groupedData)
    {
        $locationGroups = [
            'Surabaya' => [],
            'Semarang' => [],
            'Unknown' => []
        ];
        
        foreach ($groupedData as $key => $group) {
            $location = $this->getLocationFromDeliveryOrder($group['delivery']);
            $locationGroups[$location][$key] = $group;
        }
        
        return $locationGroups;
    }

