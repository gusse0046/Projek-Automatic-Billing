    private function normalizeCustomerName($name)
    {
        $normalized = str_replace([',', '.', '  '], [' ', ' ', ' '], $name);
        $suffixes = [
            'INC.' => 'INC',
            'Inc.' => 'INC', 
            'LLC.' => 'LLC',
            'Corp.' => 'CORP',
            'Ltd.' => 'LTD',
            'CO.' => 'CO'
        ];
        
        foreach ($suffixes as $from => $to) {
            $normalized = str_ireplace($from, $to, $normalized);
        }
        
        return preg_replace('/\s+/', ' ', trim($normalized));
    }

    private function formatEmailDisplay($email)
    {
        $typeLabels = [
            'primary' => '[PRIMARY]',
            'secondary' => '[SEC]', 
            'accounting' => '[ACC]',
            'logistic' => '[LOG]',
            'other' => '[OTHER]'
        ];
        
        $label = $typeLabels[$email->email_type] ?? '[STD]';
        $contact = $email->contact_name ? " ({$email->contact_name})" : '';
        
        return "{$email->email}{$contact} - " . ucfirst($email->email_type) . " {$label}";
    }

    private function fetchBillingDataWithFallback($preferredEndpoint = null): ?array
    {
        try {
            $endpoint = $preferredEndpoint ?? 'fast';
            
            if ($endpoint === 'fast') {
                $response = Http::timeout(30)->get($this->billingApiUrl . '/api/billing_data_fast');
                
                if ($response->successful()) {
                    $responseData = $response->json();
                    if (isset($responseData['data']) && is_array($responseData['data'])) {
                        Log::info('Fast billing data fetched successfully', [
                            'record_count' => count($responseData['data'])
                        ]);
                        return $responseData['data'];
                    }
                }
                
                Log::warning('Fast endpoint failed, trying standard endpoint');
            }
            
            $response = Http::timeout(180)->get($this->billingApiUrl . '/api/billing_data');
            
            if ($response->successful()) {
                $responseData = $response->json();
                if (isset($responseData['data']) && is_array($responseData['data'])) {
                    Log::info('Standard billing data fetched successfully', [
                        'record_count' => count($responseData['data'])
                    ]);
                    return $responseData['data'];
                }
            }
        } catch (\Exception $e) {
            Log::error('Both endpoints failed: ' . $e->getMessage());
        }
        
        return null;
    }

