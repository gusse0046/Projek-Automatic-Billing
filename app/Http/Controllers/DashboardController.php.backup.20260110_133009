            Log::info('=== CALLING Mail::send() ===');
            
            Mail::send('emails.documents-to-buyer', $emailData, function ($message) use ($emailData, $attachments, $subject) {
                $toEmail = $emailData['primary_email'];
                $toName = $emailData['primary_contact_name'] ?: '';
                
                if (empty($toEmail) || !is_string($toEmail)) {
                    throw new \Exception('Primary email address is invalid: ' . var_export($toEmail, true));
