    /**
     * Get buyer emails with better validation
     */
    public function getBuyerEmails($customer_name)
    {
        try {
            Log::info("=== GETTING BUYER EMAILS FOR CUSTOMER ===", [
                'customer_name' => $customer_name,
                'timestamp' => now()->toDateTimeString()
            ]);
            
            $emails = DB::table('buyer_emails')
                ->where('buyer_name', $customer_name)
                ->orderBy('is_primary', 'desc')
                ->orderBy('email_type')
                ->get();
            
            if ($emails->isEmpty()) {
                Log::info('Direct match failed, trying normalized name...');
                
                $normalizedName = $this->normalizeCustomerName($customer_name);
                $emails = DB::table('buyer_emails')
                    ->where('buyer_name', 'LIKE', "%{$normalizedName}%")
                    ->orderBy('is_primary', 'desc')
                    ->orderBy('email_type')
                    ->get();
            }
            
            if ($emails->isEmpty()) {
                Log::info('Normalized match failed, trying case-insensitive...');
                
                $emails = DB::table('buyer_emails')
                    ->whereRaw('UPPER(buyer_name) = ?', [strtoupper($customer_name)])
                    ->orderBy('is_primary', 'desc')
                    ->orderBy('email_type')
                    ->get();
            }
            
            if ($emails->isEmpty()) {
                Log::warning("No emails found for customer: {$customer_name}");
                
                $totalEmails = DB::table('buyer_emails')->count();
                $allCustomers = DB::table('buyer_emails')->distinct()->pluck('buyer_name')->take(10);
                
                return response()->json([
                    'success' => false,
                    'message' => 'No emails found for this buyer',
                    'emails' => [],
                    'debug_info' => [
                        'searched_customer' => $customer_name,
                        'normalized_customer' => $this->normalizeCustomerName($customer_name),
                        'total_emails_in_db' => $totalEmails,
                        'sample_customers' => $allCustomers->toArray()
                    ]
                ]);
            }
            
            $validEmails = $emails->filter(function($email) {
                return !empty($email->email) && !empty($email->id);
            });
            
            if ($validEmails->isEmpty()) {
                Log::error("Found emails but all are invalid for customer: {$customer_name}");
                return response()->json([
                    'success' => false,
                    'message' => 'Found emails but they contain invalid data',
                    'emails' => []
                ]);
            }
            
            $formattedEmails = $validEmails->map(function($email) {
                return [
                    'id' => intval($email->id),
                    'email' => $email->email,
                    'contact_name' => $email->contact_name,
                    'email_type' => $email->email_type,
                    'is_primary' => $email->is_primary,
                    'buyer_name' => $email->buyer_name,
                    'display_name' => $this->formatEmailDisplay($email)
                ];
            });
            
            Log::info("Found and validated " . count($formattedEmails) . " emails for customer: {$customer_name}");
            
            return response()->json([
                'success' => true,
                'emails' => $formattedEmails,
                'count' => count($formattedEmails),
                'customer_name' => $customer_name
            ]);
            
        } catch (\Exception $e) {
            Log::error("Error getting buyer emails for {$customer_name}: " . $e->getMessage());
            Log::error("Stack trace: " . $e->getTraceAsString());
            
            return response()->json([
                'success' => false,
                'message' => 'Error loading buyer emails: ' . $e->getMessage(),
                'emails' => [],
                'error_code' => 'DATABASE_ERROR'
            ]);
        }
    }

    /**
     * Get buyer emails with multiple fallback strategies
     */
    private function getBuyerEmailsWithFallback($customerName, $selectedEmailIds)
    {
        Log::info('=== GETTING BUYER EMAILS WITH FALLBACK ===', [
            'customer_name' => $customerName,
            'selected_email_ids' => $selectedEmailIds
        ]);

        $buyerEmails = DB::table('buyer_emails')
            ->whereIn('id', $selectedEmailIds)
            ->where('buyer_name', $customerName)
            ->get();

        if ($buyerEmails->isNotEmpty()) {
            Log::info('Strategy 1 SUCCESS: Direct match found', [
                'found_count' => $buyerEmails->count()
            ]);
            return $buyerEmails;
        }

        Log::info('Strategy 1 FAILED: No direct match, trying normalized name...');

        $normalizedName = $this->normalizeCustomerName($customerName);
        $buyerEmails = DB::table('buyer_emails')
            ->whereIn('id', $selectedEmailIds)
            ->where('buyer_name', $normalizedName)
            ->get();

        if ($buyerEmails->isNotEmpty()) {
            Log::info('Strategy 2 SUCCESS: Normalized name match found', [
                'normalized_name' => $normalizedName,
                'found_count' => $buyerEmails->count()
            ]);
            return $buyerEmails;
        }

        Log::info('Strategy 2 FAILED: No normalized match, trying case-insensitive...');

        $buyerEmails = DB::table('buyer_emails')
            ->whereIn('id', $selectedEmailIds)
            ->whereRaw('UPPER(buyer_name) = ?', [strtoupper($customerName)])
            ->get();

        if ($buyerEmails->isNotEmpty()) {
            Log::info('Strategy 3 SUCCESS: Case-insensitive match found', [
                'found_count' => $buyerEmails->count()
            ]);
            return $buyerEmails;
        }

        Log::info('Strategy 3 FAILED: No case-insensitive match, trying fuzzy match...');

        $buyerEmails = DB::table('buyer_emails')
            ->whereIn('id', $selectedEmailIds)
            ->get();

        if ($buyerEmails->isNotEmpty()) {
            foreach ($buyerEmails as $email) {
                if ($email->buyer_name !== $customerName) {
                    Log::warning('Customer name mismatch but email ID found', [
                        'email_id' => $email->id,
                        'expected_customer' => $customerName,
                        'found_customer' => $email->buyer_name,
                        'email_address' => $email->email
                    ]);
                }
            }

            Log::info('Strategy 4 SUCCESS: Email IDs found (ignoring customer name)', [
                'found_count' => $buyerEmails->count(),
                'warning' => 'Customer name may not match exactly'
            ]);
            return $buyerEmails;
        }

        Log::error('ALL STRATEGIES FAILED: No buyer emails found', [
            'customer_name' => $customerName,
            'normalized_name' => $normalizedName,
            'selected_email_ids' => $selectedEmailIds,
            'total_emails_in_db' => DB::table('buyer_emails')->count(),
            'emails_for_customer' => DB::table('buyer_emails')->where('buyer_name', $customerName)->count()
        ]);

        return collect([]);
    }

