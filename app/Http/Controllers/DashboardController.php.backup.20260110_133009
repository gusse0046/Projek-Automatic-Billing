    /**
     * Manual SAP sync
     */
    public function syncSapNow(Request $request)
    {
        try {
            $forceSync = $request->get('force', false);
            $endpoint = $request->get('endpoint', 'fast');
            
            Log::info('Manual SAP sync requested', [
                'force' => $forceSync,
                'endpoint' => $endpoint,
                'user' => Auth::user()->name ?? 'Unknown'
            ]);
            
            $startTime = microtime(true);
            
            $billingData = $this->fetchBillingDataWithFallback($endpoint);
            
            if ($billingData === null || !is_array($billingData)) {
                throw new \Exception('Failed to fetch data from SAP');
            }
            
            $fetchDuration = microtime(true) - $startTime;
            
            $stored = SapDataStorage::storeBillingData(
                $billingData, 
                $endpoint, 
                $fetchDuration
            );
            
            if (!$stored) {
                throw new \Exception('Failed to store data to database');
            }
            
            Log::info('Manual SAP sync completed successfully', [
                'record_count' => count($billingData),
                'endpoint' => $endpoint,
                'duration' => $fetchDuration,
                'storage_id' => $stored->id ?? 'unknown'
            ]);
            
            return response()->json([
                'success' => true,
                'message' => 'SAP data synced successfully',
                'record_count' => count($billingData),
                'endpoint_used' => $endpoint,
                'fetch_duration' => round($fetchDuration, 2),
                'storage_id' => $stored->id ?? null,
                'timestamp' => now()->toDateTimeString()
            ]);
            
        } catch (\Exception $e) {
            Log::error('Manual SAP sync failed: ' . $e->getMessage());
            
            return response()->json([
                'success' => false,
                'message' => 'SAP sync failed: ' . $e->getMessage(),
                'timestamp' => now()->toDateTimeString()
            ], 500);
        }
    }

