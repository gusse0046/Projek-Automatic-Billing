     */
    private function getBillingDocumentFromGroupedData($deliveryOrder, $customerName)
    {
        try {
            if ($this->billingData && is_array($this->billingData)) {
                foreach ($this->billingData as $record) {
                    if (($record['Delivery'] ?? '') === $deliveryOrder && 
                        ($record['Customer Name'] ?? '') === $customerName) {
                        $billingDoc = $record['Billing Document'] ?? null;
                        
                        if ($billingDoc && 
                            trim($billingDoc) !== '' && 
                            $billingDoc !== $deliveryOrder &&
                            $billingDoc !== '0') {
                            return $billingDoc;
                        }
                    }
