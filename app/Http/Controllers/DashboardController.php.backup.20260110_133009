    /**
     * Get EXIM documents for Finance dashboard dengan real-time integration
     */
   private function getEximDocumentsForFinance($groupedData)
{
    $eximDocuments = [];
    
    // Define Finance document types
    $financeDocTypes = ['INVOICE', 'PACKING_LIST', 'PAYMENT_INTRUCTION', 'PAYMENT_INSTRUCTION'];
    
    foreach ($groupedData as $key => $group) {
        $delivery = $group['delivery'];
        $customerName = $group['customer_name'];
        $billingDoc = $group['billing_document'] ?? null; // ✅ Get billing document
        
        try {
            $newUploadKey = "finance_new_upload_{$delivery}_{$customerName}";
            $newUploadData = Cache::get($newUploadKey);
            
            // ✅ CRITICAL FIX: Filter by billing_document
            $query = DocumentUpload::where('delivery_order', $delivery)
                                   ->where('customer_name', $customerName)
                                   ->orderBy('uploaded_at', 'desc');
            
            if ($billingDoc && $billingDoc !== $delivery) {
                $query->where(function($q) use ($billingDoc, $delivery) {
                    $q->where('billing_document', $billingDoc)
                      ->orWhereNull('billing_document')
                      ->orWhere('billing_document', '')
                      ->orWhere('billing_document', $delivery);
                });
            }
            
            $allUploads = $query->get();
            
            // Initialize structure
            $eximDocuments[$key] = [
                'exim_documents' => [],
                'finance_documents' => [],
                'integration_info' => [
                    'has_new_upload' => $newUploadData ? true : false,
                    'last_exim_upload' => $allUploads->whereIn('team', ['Exim', 'Logistic'])->max('uploaded_at'),
                    'new_upload_info' => $newUploadData
                ]
            ];
            
            // Process each document
            foreach ($allUploads as $upload) {
                $normalizedDocType = strtoupper(trim($upload->document_type));
                
                $docInfo = [
                    'id' => $upload->id,
                    'file_name' => $upload->file_name,
                    'uploaded_by' => $upload->uploaded_by ?? 'System',
                    'uploaded_at' => $upload->uploaded_at,
                    'team' => $upload->team ?? 'Unknown',
                    'integration_source' => 'EXIM_Dashboard'
                ];
                
                // Check if it's a finance document
                $isFinanceDoc = in_array($normalizedDocType, $financeDocTypes);
                
                if ($isFinanceDoc) {
                    // Finance document
                    $eximDocuments[$key]['finance_documents'][$normalizedDocType] = $docInfo;
                } else {
                    // EXIM document (including CONTAINER_LOAD)
                    if (!isset($eximDocuments[$key]['exim_documents'][$normalizedDocType])) {
                        $eximDocuments[$key]['exim_documents'][$normalizedDocType] = [];
                    }
                    $eximDocuments[$key]['exim_documents'][$normalizedDocType][] = $docInfo;
                }
            }
            
        } catch (\Exception $e) {
            Log::error('Error getting EXIM documents for Finance: ' . $e->getMessage());
            $eximDocuments[$key] = [
                'exim_documents' => [],
                'finance_documents' => [],
                'integration_info' => ['error' => $e->getMessage()]
            ];
        }
    }
    
    return $eximDocuments;
}


