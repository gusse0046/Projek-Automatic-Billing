    /**
     * Batch load documents untuk multiple deliveries sekaligus
     */
  public function getBatchDocuments(Request $request)
    {
        try {
            $deliveries = $request->get('deliveries', []);
            
            if (empty($deliveries)) {
                return response()->json(['success' => false, 'message' => 'No deliveries provided']);
            }
            
            Log::info('📦 BATCH LOADING DOCUMENTS', [
                'delivery_count' => count($deliveries),
                'deliveries' => array_map(function($d) {
                    return [
                        'delivery' => $d['delivery_order'] ?? 'N/A',
                        'billing' => $d['billing_document'] ?? 'N/A',
                        'customer' => substr($d['customer_name'] ?? '', 0, 20)
                    ];
                }, $deliveries)
            ]);
            
            $batchResults = [];
            $deliveryOrders = array_column($deliveries, 'delivery_order');
            
            // Base query
            $query = DocumentUpload::whereIn('delivery_order', $deliveryOrders)
                ->select('id', 'delivery_order', 'customer_name', 'billing_document', 'document_type', 
                         'file_name', 'file_type', 'uploaded_at', 'uploaded_by', 'team');
            
            // ✅ CRITICAL: Check if billing_document filtering is needed
            $hasBillingFilter = false;
            foreach ($deliveries as $delivery) {
                if (isset($delivery['billing_document']) && !empty($delivery['billing_document'])) {
                    $hasBillingFilter = true;
                    break;
                }
            }
            
            // ✅ Apply billing filter if needed
            if ($hasBillingFilter) {
                Log::info('✅ BILLING FILTER DETECTED');
                
                $query->where(function($q) use ($deliveries) {
                    foreach ($deliveries as $delivery) {
                        $deliveryOrder = $delivery['delivery_order'];
                        $billingDocument = $delivery['billing_document'] ?? null;
                        
                        if ($billingDocument && $billingDocument !== $deliveryOrder) {
                            $q->orWhere(function($subQ) use ($deliveryOrder, $billingDocument) {
                                $subQ->where('delivery_order', $deliveryOrder)
                                     ->where(function($billQ) use ($billingDocument, $deliveryOrder) {
                                         $billQ->where('billing_document', $billingDocument)
                                               ->orWhere('billing_document', $deliveryOrder)
                                               ->orWhereNull('billing_document');
                                     });
                            });
                        } else {
                            $q->orWhere('delivery_order', $deliveryOrder);
                        }
                    }
                });
            }
            
            $allDocuments = $query->orderBy('delivery_order')
                                 ->orderBy('document_type')
                                 ->orderBy('created_at', 'desc')
                                 ->get();
            
            Log::info('📄 DOCUMENTS LOADED', [
                'total_documents' => $allDocuments->count()
            ]);
            
            // ✅ Group documents per billing
            foreach ($deliveries as $delivery) {
                $deliveryOrder = $delivery['delivery_order'];
                $customerName = $delivery['customer_name'];
                $billingDocument = $delivery['billing_document'] ?? null;
                
                // Create unique key with billing
                if ($billingDocument && $billingDocument !== $deliveryOrder) {
                    $key = $deliveryOrder . '_' . $billingDocument . '_' . $customerName;
                } else {
                    $key = $deliveryOrder . '_' . $customerName;
                }
                
                // Filter documents for THIS specific billing
                $documents = $allDocuments->filter(function($doc) use ($deliveryOrder, $customerName, $billingDocument) {
                    $matchDelivery = $doc->delivery_order === $deliveryOrder;
                    $matchCustomer = $doc->customer_name === $customerName;
                    
                    // ✅ FILTER BY BILLING DOCUMENT
                    if ($billingDocument && $billingDocument !== $deliveryOrder) {
                        $matchBilling = ($doc->billing_document === $billingDocument) ||
                                      ($doc->billing_document === $deliveryOrder) ||
                                      (empty($doc->billing_document));
                        return $matchDelivery && $matchCustomer && $matchBilling;
                    }
                    
                    return $matchDelivery && $matchCustomer;
                });
                
                Log::info('📋 FILTERED DOCUMENTS', [
                    'delivery' => $deliveryOrder,
                    'billing' => $billingDocument,
                    'doc_count' => $documents->count()
                ]);
                
                // Group by document type
                $groupedByType = [];
                foreach ($documents as $doc) {
                    $docType = $doc->document_type;
                    
                    if (!isset($groupedByType[$docType])) {
                        $groupedByType[$docType] = [];
                    }
                    
                    $groupedByType[$docType][] = [
                        'id' => $doc->id,
                        'file_name' => $doc->file_name,
                        'file_type' => $doc->file_type,
                        'uploaded_by' => $doc->uploaded_by ?? 'System',
                        'uploaded_at' => $doc->uploaded_at ? $doc->uploaded_at->format('d M Y H:i') : '-',
                        'billing_document' => $doc->billing_document,
                        'team' => $doc->team
                    ];
                }
                
                $batchResults[$key] = $groupedByType;
            }
            
            Log::info('✅ BATCH LOADING COMPLETED', [
                'processed_deliveries' => count($deliveries),
                'total_documents' => $allDocuments->count()
            ]);
            
            return response()->json([
                'success' => true,
                'documents' => $batchResults,
                'total_deliveries' => count($deliveries),
                'total_documents' => $allDocuments->count(),
                'timestamp' => now()->toDateTimeString()
            ]);
            
        } catch (\Exception $e) {
            Log::error('❌ BATCH LOADING FAILED', [
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            
            return response()->json([
                'success' => false,
                'message' => 'Failed to load documents: ' . $e->getMessage()
            ], 500);
        }
    }

    /**
     * Get document counts untuk statistik cepat
     */
    public function getDocumentCounts(Request $request)
    {
        try {
            $deliveries = $request->get('deliveries', []);
            
            if (empty($deliveries)) {
                return response()->json(['success' => false, 'message' => 'No deliveries provided']);
            }
            
            $documentCounts = DocumentUpload::whereIn('delivery_order', array_column($deliveries, 'delivery_order'))
                ->select('delivery_order', 'customer_name', 'document_type', DB::raw('COUNT(*) as count'))
                ->groupBy('delivery_order', 'customer_name', 'document_type')
                ->get()
                ->groupBy(['delivery_order', 'customer_name']);
            
            $results = [];
            foreach ($deliveries as $delivery) {
                $deliveryOrder = $delivery['delivery_order'];
                $customerName = $delivery['customer_name'];
                $key = $deliveryOrder . '_' . $customerName;
                
                $counts = $documentCounts->get($deliveryOrder, collect())->get($customerName, collect());
                
                $typeCounts = [];
                foreach ($counts as $count) {
                    $typeCounts[$count->document_type] = $count->count;
                }
                
                $results[$key] = $typeCounts;
            }
            
            return response()->json([
                'success' => true,
                'document_counts' => $results,
                'timestamp' => now()->toDateTimeString()
            ]);
            
        } catch (\Exception $e) {
            Log::error('Document count loading failed: ' . $e->getMessage());
            
            return response()->json([
                'success' => false,
                'message' => 'Failed to load document counts: ' . $e->getMessage()
            ], 500);
        }
    }

