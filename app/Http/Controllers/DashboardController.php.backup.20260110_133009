                Log::info('Setting TO address', [
                    'email' => $toEmail,
                    'name' => $toName,
                    'email_type' => gettype($toEmail)
                ]);
                
                $message->to($toEmail, $toName)
                        ->subject($subject)
                        ->from('ar.kmi@pawindo.com', 'KMI Finance - Account Receivable');

                foreach ($emailData['cc_emails'] as $ccEmail) {
                    if (!empty($ccEmail['email']) && filter_var($ccEmail['email'], FILTER_VALIDATE_EMAIL)) {
                        $message->cc($ccEmail['email'], $ccEmail['contact_name'] ?: '');
                        Log::info('Added CC', ['email' => $ccEmail['email']]);
                    } else {
                        Log::warning('Skipped invalid CC email', ['email' => $ccEmail['email'] ?? 'null']);
                    }
                }

                foreach ($attachments as $attachment) {
                    $message->attach($attachment['path'], [
                        'as' => $attachment['original_name'],
                        'mime' => $attachment['mime']
                    ]);
                    Log::info('Attached file', ['name' => $attachment['original_name']]);
                }
