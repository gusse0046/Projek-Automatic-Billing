    public function refreshBillingData(Request $request)
    {
        try {
            $forceSync = $request->get('force', false);
            $endpoint = $request->get('endpoint', 'fast');
            
            Log::info('Dashboard refresh requested', [
                'force' => $forceSync,
                'endpoint' => $endpoint,
                'user' => Auth::user()->name ?? 'Unknown'
            ]);
            
            if (!$forceSync) {
                $cachedData = $this->getBillingDataWithDatabaseCaching();
                if ($cachedData !== null) {
                    $groupedData = $this->groupBillingDataWithStatusFixed($cachedData);
                    
                    return response()->json([
                        'status' => 'success',
                        'data' => $groupedData,
                        'data_source' => 'database_cache',
                        'total_records' => count($cachedData),
                        'grouped_count' => count($groupedData),
                        'timestamp' => now()->toDateTimeString(),
                        'cache_age_minutes' => SapDataStorage::getCacheAgeMinutes()
                    ]);
                }
            }
            
            $billingData = $this->fetchBillingDataWithFallback($endpoint);
            
            if ($billingData !== null && is_array($billingData)) {
                try {
                    SapDataStorage::storeBillingData($billingData, $endpoint, 0);
                    Log::info('Fresh SAP data stored to database');
                } catch (\Exception $e) {
                    Log::warning('Failed to store fresh SAP data: ' . $e->getMessage());
                }
                
                $groupedData = $this->groupBillingDataWithStatusFixed($billingData);
                
                return response()->json([
                    'status' => 'success',
                    'data' => $groupedData,
                    'data_source' => 'sap_fresh',
                    'endpoint_used' => $endpoint,
                    'total_records' => count($billingData),
                    'grouped_count' => count($groupedData),
                    'timestamp' => now()->toDateTimeString()
                ]);
            }
            
            return response()->json([
                'status' => 'error',
                'message' => 'Unable to fetch billing data from SAP',
                'timestamp' => now()->toDateTimeString()
            ], 503);
            
        } catch (\Exception $e) {
            Log::error('Error refreshing billing data: ' . $e->getMessage());
            
            return response()->json([
                'status' => 'error',
                'message' => $e->getMessage(),
                'timestamp' => now()->toDateTimeString()
            ], 500);
        }
    }

