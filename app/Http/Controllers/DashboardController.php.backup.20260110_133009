                'next_scheduled_sync' => 'Unknown',
                'error' => $e->getMessage()
            ];
        }
    }

    private function triggerEmergencyDailySync()
    {
        try {
            \Illuminate\Support\Facades\Artisan::queue('sap:sync-to-db', [
                '--force' => true,
                '--endpoint' => 'fast',
                '--daily' => true
            ]);
            
            Log::warning('Emergency daily sync dispatched - cache was empty');
            
        } catch (\Exception $e) {
            Log::error('Failed to dispatch emergency daily sync: ' . $e->getMessage());
        }
    }

    /**
 * ✅ NEW: Calculate buyer financial summary dengan currency separation
 */
private function calculateBuyerFinancialSummary($groupedData)
{
    $buyerFinancialSummary = [];
    
    // Group by customer
    $grouped = collect($groupedData)->groupBy('customer_name');
    
    foreach ($grouped as $customerName => $deliveries) {
        // Initialize totals per currency per location
        $surabayaTotals = []; // ['USD' => 0, 'IDR' => 0]
        $semarangTotals = []; // ['USD' => 0, 'IDR' => 0]
        
        foreach ($deliveries as $delivery) {
            $location = $delivery['location'];
            $currency = $delivery['currency'] ?? 'USD';
            $netValue = floatval($delivery['total_net_value'] ?? 0);
            
            if ($location === 'Surabaya') {
                if (!isset($surabayaTotals[$currency])) {
                    $surabayaTotals[$currency] = 0;
                }
                $surabayaTotals[$currency] += $netValue;
                
            } elseif ($location === 'Semarang') {
                if (!isset($semarangTotals[$currency])) {
                    $semarangTotals[$currency] = 0;
                }
                $semarangTotals[$currency] += $netValue;
            }
        }
        
        $buyerFinancialSummary[] = [
            'name' => $customerName,
            'slug' => Str::slug($customerName),
            'surabaya_totals' => $surabayaTotals,  // ✅ Array per currency
            'semarang_totals' => $semarangTotals,  // ✅ Array per currency
            'delivery_count' => $deliveries->count(),
            'all_currencies' => array_unique(array_merge(
                array_keys($surabayaTotals),
                array_keys($semarangTotals)
            ))
        ];
    }
    
    // Sort by name
    usort($buyerFinancialSummary, function($a, $b) {
        return strcmp($a['name'], $b['name']);
    });
    
    return $buyerFinancialSummary;
}

