                    'message' => 'No billing data available'
                ]);
            }
            
            $allGroupedData = $this->groupBillingDataWithStatusFixed($billingData);
            
        foreach ($allGroupedData as $key => $group) {
    $allGroupedData[$key]['location'] = $this->getLocationFromDeliveryOrder($group['delivery']);
}
unset($key, $group);
            
            if ($location !== 'all') {
                $allGroupedData = array_filter($allGroupedData, function($group) use ($location) {
                    return strtolower($group['location']) === strtolower($location);
                });
            }
            
            $notificationCounts = $this->getBuyerNotificationCounts($allGroupedData);
            
            return response()->json([
                'success' => true,
                'notifications' => $notificationCounts,
                'timestamp' => now()->toDateTimeString()
            ]);
            
        } catch (\Exception $e) {
            Log::error('Error getting buyer notifications: ' . $e->getMessage());
            
            return response()->json([
                'success' => false,
                'message' => 'Error: ' . $e->getMessage()
            ], 500);
        }
    }

    /**
 * Get buyer notification counts khusus untuk EXIM Dashboard
 * Hanya hitung EXIM documents, exclude Finance documents
 */
private function getBuyerNotificationCountsForExim($groupedData)
{
    $notificationCounts = [];
    
    foreach ($groupedData as $key => $group) {
        $customerName = $group['customer_name'];
        $deliveryOrder = $group['delivery'];
        
        // Initialize counter
        if (!isset($notificationCounts[$customerName])) {
            $notificationCounts[$customerName] = [
                'completed_count' => 0,
                'billed_count' => 0,
                'total_deliveries' => 0
            ];
        }
        
        try {
            // ✅ GUNAKAN METHOD KHUSUS EXIM (sudah ada di BillingStatus.php)
            $progress = BillingStatus::getDetailedProgressForExim($deliveryOrder, $customerName);
            
            $eximComplete = $progress['exim_complete'] ?? false;
            
            // Get billing status
            $billingStatus = BillingStatus::where('delivery_order', $deliveryOrder)
                                        ->where('customer_name', $customerName)
                                        ->first();
            
            $status = $billingStatus ? $billingStatus->status : 'outstanding';
            
            // Count logic
            if ($eximComplete && $status !== 'sent') {
                $notificationCounts[$customerName]['completed_count']++;
            }
            
            if ($status === 'sent') {
                $notificationCounts[$customerName]['billed_count']++;
            }
            
            $notificationCounts[$customerName]['total_deliveries']++;
            
        } catch (\Exception $e) {
            \Log::error("Failed to count EXIM notifications: " . $e->getMessage());
            $notificationCounts[$customerName]['total_deliveries']++;
        }
    }
    
    return $notificationCounts;
}

