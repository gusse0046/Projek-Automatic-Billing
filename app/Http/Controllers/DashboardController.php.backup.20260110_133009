            return "{$greeting}\n\n" .
                   "Please find the attached export documents for {$displayNumber}{$bookingInfo}.\n\n" .
                   "Please review all documents carefully. Billing document will be sent separately once available.\n\n" .
                   "Best Regards,\n" .
                   "KMI Finance - Account Receivable";
        }
