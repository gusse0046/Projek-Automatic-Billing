    private function getDocumentSettingsForExim($groupedData)
    {
        $documentSettings = [];
        
        if (!class_exists('App\Models\DocumentSetting')) {
            return $documentSettings;
        }
        
        $allSettings = DocumentSetting::all();
        $settingsMap = [];
        
        foreach ($allSettings as $setting) {
            $originalName = $setting->customer_name;
            $normalizedName = $this->normalizeCustomerName($originalName);
            
            $settingsMap[$originalName] = $setting->allowed_documents;
            $settingsMap[$normalizedName] = $setting->allowed_documents;
            $settingsMap[strtoupper($originalName)] = $setting->allowed_documents;
            $settingsMap[strtolower($originalName)] = $setting->allowed_documents;
            
            $cleanName = preg_replace('/[^a-zA-Z0-9\s]/', '', $originalName);
            $settingsMap[$cleanName] = $setting->allowed_documents;
            $settingsMap[strtoupper($cleanName)] = $setting->allowed_documents;
        }
        
        foreach ($groupedData as $group) {
            $customerName = $group['customer_name'];
            $found = false;
            
            $variations = [
                $customerName,
                $this->normalizeCustomerName($customerName),
                strtoupper($customerName),
                strtolower($customerName),
                trim($customerName),
                preg_replace('/[^a-zA-Z0-9\s]/', '', $customerName),
                str_replace(['INC.', 'LLC.', 'CO.'], ['INC', 'LLC', 'CO'], $customerName),
                str_replace([',', '.'], '', $customerName)
            ];
            
            foreach ($variations as $variation) {
                if (isset($settingsMap[$variation])) {
                    $documentSettings[$customerName] = $settingsMap[$variation];
                    $found = true;
                    break;
                }
            }
            
            if (!$found) {
                $documentSettings[$customerName] = [];
            }
        }
        
        return $documentSettings;
    }

