    private function getBuyerEmailsWithCCLogic($customerName, $selectedEmailIds)
    {
        try {
            $selectedEmails = $this->getBuyerEmailsWithFallback($customerName, $selectedEmailIds);
            
            if ($selectedEmails->isEmpty()) {
                Log::error('No emails found after fallback', [
                    'customer' => $customerName,
                    'selected_ids' => $selectedEmailIds
                ]);
                return ['primary' => null, 'cc_emails' => [], 'total_recipients' => 0];
            }

            $primaryEmail = $selectedEmails->where('is_primary', 1)->first();
            
            if (!$primaryEmail && $selectedEmails->isNotEmpty()) {
                $primaryEmail = $selectedEmails->first();
                Log::warning('No primary email marked, using first email as primary', [
                    'email' => $primaryEmail->email ?? 'unknown'
                ]);
            }
            
            if (!$primaryEmail) {
                Log::error('No primary email object found', [
                    'customer' => $customerName,
                    'selected_count' => $selectedEmails->count()
                ]);
                return ['primary' => null, 'cc_emails' => [], 'total_recipients' => 0];
            }

            if (!isset($primaryEmail->email) || empty($primaryEmail->email)) {
                Log::error('Primary email object missing email property', [
                    'customer' => $customerName,
                    'primary_object' => $primaryEmail,
                    'object_properties' => get_object_vars($primaryEmail)
                ]);
                return ['primary' => null, 'cc_emails' => [], 'total_recipients' => 0];
            }

            if (!filter_var($primaryEmail->email, FILTER_VALIDATE_EMAIL)) {
                Log::error('Invalid primary email format', [
                    'email' => $primaryEmail->email
                ]);
                return ['primary' => null, 'cc_emails' => [], 'total_recipients' => 0];
            }

            $ccEmails = $selectedEmails->filter(function($email) use ($primaryEmail) {
                return $email->id !== $primaryEmail->id;
            })->values()->map(function($email) {
                return [
                    'id' => $email->id,
                    'email' => $email->email,
                    'contact_name' => $email->contact_name,
                    'email_type' => $email->email_type ?? 'standard',
                    'is_primary' => $email->is_primary
                ];
            })->toArray();

            Log::info('=== CC EMAIL LOGIC SUCCESS ===', [
                'customer_name' => $customerName,
                'primary_email' => $primaryEmail->email,
                'primary_contact' => $primaryEmail->contact_name ?? 'N/A',
                'primary_type' => gettype($primaryEmail),
                'primary_is_object' => is_object($primaryEmail),
                'cc_emails_count' => count($ccEmails),
                'total_recipients' => $selectedEmails->count()
            ]);

            return [
                'primary' => $primaryEmail,
                'cc_emails' => $ccEmails,
                'total_recipients' => $selectedEmails->count()
            ];
            
        } catch (\Exception $e) {
            Log::error('Error in getBuyerEmailsWithCCLogic', [
                'error' => $e->getMessage(),
                'trace' => $e->getTraceAsString()
            ]);
            return ['primary' => null, 'cc_emails' => [], 'total_recipients' => 0];
        }
    }

