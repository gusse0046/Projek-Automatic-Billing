    private function getLocationStats()
    {
        try {
            $billingData = $this->getBillingDataWithDatabaseCaching();
            if (!$billingData) return ['surabaya' => 0, 'semarang' => 0, 'local' => 0];
            
            $groupedData = $this->groupBillingDataWithStatusFixed($billingData);
            
            $surabayaCount = 0;
            $semarangCount = 0;
            $localCount = 0;
            
            foreach ($groupedData as &$group) {
                $group['location'] = $this->getLocationFromDeliveryOrder($group['delivery']);
                $group['is_local'] = $this->isLocalDelivery($group['billing_document'] ?? '');
                
                // Count LOCAL: Billing Doc 315/316 AND DO 211/212
                $deliveryPrefix = substr($group['delivery'], 0, 3);
                if ($group['is_local'] && in_array($deliveryPrefix, ['211', '212'])) {
                    $localCount++;
                } else {
                    // ✅ HANYA COUNT NON-LOCAL untuk Surabaya dan Semarang
                    if ($group['location'] === 'Surabaya') {
                        $surabayaCount++;
                    } elseif ($group['location'] === 'Semarang') {
                        $semarangCount++;
                    }
                }
            }
            
            return [
                'surabaya' => $surabayaCount,
                'semarang' => $semarangCount,
                'local' => $localCount
            ];
        } catch (\Exception $e) {
            return ['surabaya' => 0, 'semarang' => 0, 'local' => 0];
        }
    }

    private function buildAllTeamDocuments($groupedData)
    {
        $allTeamDocuments = [];
        
        foreach ($groupedData as $key => $group) {
            $delivery = $group['delivery'];
            $customer = $group['customer_name'];
            $billingDoc = $group['billing_document'] ?? null; // ✅ Get billing document
            
            try {
                // ✅ CRITICAL FIX: Query berdasarkan billing_document jika ada
                $query = DocumentUpload::where('delivery_order', $delivery)
                                       ->where('customer_name', $customer);
                
                // ✅ Filter by billing_document jika column exists dan billing berbeda
                if ($billingDoc && $billingDoc !== $delivery) {
                    $query->where(function($q) use ($billingDoc, $delivery) {
                        $q->where('billing_document', $billingDoc)
                          ->orWhereNull('billing_document')
                          ->orWhere('billing_document', '')
                          ->orWhere('billing_document', $delivery); // Legacy: billing = delivery
                    });
                }
                
                $allUploads = $query->get();
                
                Log::debug('Document query for billing separation', [
                    'delivery' => $delivery,
                    'billing_document' => $billingDoc,
                    'documents_found' => $allUploads->count()
                ]);
                
                $financeDocuments = [];
                $eximDocuments = [];
                $logisticDocuments = [];
                
                foreach ($allUploads as $upload) {
                    $docInfo = [
                        'id' => $upload->id,
                        'file_name' => $upload->file_name,
                        'file_type' => $upload->file_type,
                        'document_type' => $upload->document_type,
                        'uploaded_by' => $upload->uploaded_by ?? 'System',
                        'uploaded_at' => $upload->uploaded_at
                    ];
                    
                    if (in_array($upload->document_type, BillingStatus::FINANCE_REQUIRED_DOCUMENTS)) {
                        // Finance documents
                        $financeDocuments[$upload->document_type] = $docInfo;
                    } elseif (in_array($upload->document_type, ['CARB','CONTAINER_LOAD','CONTAINER_CHEKLIST'])) {
                        // Logistic documents - simpan di logistic_documents
                        if (!isset($logisticDocuments[$upload->document_type])) {
                            $logisticDocuments[$upload->document_type] = [];
                        }
                        $logisticDocuments[$upload->document_type][] = $docInfo;
                        
                        // ✅ CRITICAL FIX: Dokumen logistic JUGA harus masuk ke exim_documents
                        // Karena alur: Logistic → Exim → Finance
                        // Semua yang ada di Exim harus tampil di Finance juga
                        if (!isset($eximDocuments[$upload->document_type])) {
                            $eximDocuments[$upload->document_type] = [];
                        }
                        $eximDocuments[$upload->document_type][] = $docInfo;
                    } else {
                        // Exim documents (BILL OF LADING, dll)
                        if (!isset($eximDocuments[$upload->document_type])) {
                            $eximDocuments[$upload->document_type] = [];
                        }
                        $eximDocuments[$upload->document_type][] = $docInfo;
                    }
                }
                
                $financeMissing = array_diff(
                    BillingStatus::FINANCE_REQUIRED_DOCUMENTS,
                    array_keys($financeDocuments)
                );
                
                $allTeamDocuments[$key] = [
                    'finance_documents' => $financeDocuments,
                    'finance_missing' => array_values($financeMissing),
                    'exim_documents' => $eximDocuments,
                    'logistic_documents' => $logisticDocuments
                ];
                
            } catch (\Exception $e) {
                Log::error("Error building team documents for {$delivery}: " . $e->getMessage());
                $allTeamDocuments[$key] = [
                    'finance_documents' => [],
                    'finance_missing' => BillingStatus::FINANCE_REQUIRED_DOCUMENTS,
                    'exim_documents' => [],
                    'logistic_documents' => []
                ];
            }
        }
        
        return $allTeamDocuments;
    }

/**
 * Get buyer notification counts - IMPROVED & ACCURATE
 * Method ini dipanggil dari admin-finance blade dan API endpoint
 */
private function getBuyerNotificationCounts($groupedData)
{
    $notificationCounts = [];
    
    foreach ($groupedData as $key => $group) {
        $customerName = $group['customer_name'];
        $deliveryOrder = $group['delivery'];
        
        if (!isset($notificationCounts[$customerName])) {
            $notificationCounts[$customerName] = [
                'completed_count' => 0,
                'billed_count' => 0,
                'total_deliveries' => 0
            ];
        }
        
        try {
            // ✅ FIX: Ambil billing_document dari $group
            $billingDocument = $group['billing_document'] ?? null;
            
            // ✅ Pass billing document dari group data
            $progress = BillingStatus::getDetailedProgress(
                $deliveryOrder, 
                $customerName,
                $billingDocument  // ✅ BENAR: Dari $group, bukan variable yang tidak ada
            );
            
            $overallProgress = $progress['overall_progress_percentage'] ?? 0;
            $status = $progress['status'] ?? 'outstanding';
            
            if ($overallProgress >= 100 && $status !== 'sent') {
                $notificationCounts[$customerName]['completed_count']++;
            }
            
            if ($status === 'sent') {
                $notificationCounts[$customerName]['billed_count']++;
            }
            
            $notificationCounts[$customerName]['total_deliveries']++;
            
        } catch (\Exception $e) {
            \Log::error("Failed to count notifications for {$deliveryOrder}: " . $e->getMessage());
            $notificationCounts[$customerName]['total_deliveries']++;
        }
    }
    
    return $notificationCounts;
}

