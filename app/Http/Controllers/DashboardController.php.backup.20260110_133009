            Log::info("CC Email sent successfully", [
                'primary' => $emailData['primary_email'],
                'cc_count' => count($emailData['cc_emails']),
                'subject' => $subject,
                'attachments' => count($attachments)
            ]);

            return true;

        } catch (\Exception $e) {
            Log::error('CC Email sending failed', [
                'error' => $e->getMessage(),
                'error_type' => get_class($e),
                'file' => $e->getFile(),
                'line' => $e->getLine(),
                'trace' => $e->getTraceAsString(),
                'primary_data_debug' => isset($buyerEmails['primary']) ? [
                    'type' => gettype($buyerEmails['primary']),
                    'is_object' => is_object($buyerEmails['primary']),
                    'has_email_property' => isset($buyerEmails['primary']->email) ? 'yes' : 'no',
