    /**
     * Apply 40-day billing date filter
     */
    private function applyBillingDateFilter($billingData, $daysLimit = 40)
    {
        if (!is_array($billingData) || empty($billingData)) {
            return [];
        }
        
        $cutoffDate = Carbon::now()->subDays($daysLimit);
        $filteredData = [];
        $debugInfo = [
            'total_input' => count($billingData),
            'cutoff_date' => $cutoffDate->format('Y-m-d'),
            'filtered_out_count' => 0,
            'included_count' => 0,
            'no_date_count' => 0
        ];
        
        foreach ($billingData as $record) {
            $billingDate = $record['Billing Date'] ?? '';
            
            if (empty($billingDate) || trim($billingDate) === '') {
                $filteredData[] = $record;
                $debugInfo['no_date_count']++;
                $debugInfo['included_count']++;
                continue;
            }
            
            try {
                if (preg_match('/^\d{2}\.\d{2}\.\d{4}$/', $billingDate)) {
                    $parsedDate = Carbon::createFromFormat('d.m.Y', $billingDate);
                    
                    if ($parsedDate && $parsedDate->gte($cutoffDate)) {
                        $filteredData[] = $record;
                        $debugInfo['included_count']++;
                    } else {
                        $debugInfo['filtered_out_count']++;
                    }
                } else {
                    $filteredData[] = $record;
                    $debugInfo['included_count']++;
                }
            } catch (\Exception $e) {
                $filteredData[] = $record;
                $debugInfo['included_count']++;
                Log::warning('Date parsing error: ' . $e->getMessage(), [
                    'billing_date' => $billingDate,
                    'record' => $record['Delivery'] ?? 'unknown'
                ]);
            }
        }
        
        Log::info('BILLING DATE FILTER RESULTS', $debugInfo);
        
        return $filteredData;
    }

   private function groupBillingDataWithStatusFixed($billingData)
{
    if (!is_array($billingData)) {
        Log::warning('groupBillingDataWithStatus received non-array data');
        return [];
    }
    
    $grouped = [];
    $processingStats = [
        'input_records' => count($billingData),
        'processed_records' => 0,
        'skipped_records' => 0,
        'grouped_deliveries' => 0,
        'multiple_billing_detected' => 0, // ✅ NEW
        'billing_prefixes_found' => []
    ];
    
    foreach ($billingData as $index => $item) {
        if (!is_array($item)) {
            $processingStats['skipped_records']++;
            continue;
        }
        
        $delivery = $item['Delivery'] ?? '';
        $customerName = $item['Customer Name'] ?? '';
        
        if (empty($delivery)) {
            $processingStats['skipped_records']++;
            Log::debug("Skipping record {$index}: No delivery number");
            continue;
        }
        
        $location = $this->getLocationFromDeliveryOrder($delivery);
        
        // ✅ CRITICAL FIX: Gunakan billing_document sebagai bagian dari key
        // Jika 1 DO punya 2 billing docs berbeda, akan dibuat 2 entry terpisah
        $sapBillingDocument = $item['Billing Document'] ?? '';
        $validBillingDocument = null;
        
        if (!empty($sapBillingDocument) && 
            trim($sapBillingDocument) !== '' && 
            $sapBillingDocument !== $delivery &&
            $sapBillingDocument !== '0') {
            $validBillingDocument = trim($sapBillingDocument);
            
            $billingPrefix = substr($validBillingDocument, 0, 3);
            if (!in_array($billingPrefix, $processingStats['billing_prefixes_found'])) {
                $processingStats['billing_prefixes_found'][] = $billingPrefix;
            }
        }
        
        // ✅ NEW KEY STRATEGY:
        // - Jika ada billing doc yang valid -> gunakan sebagai unique key
        // - Jika tidak ada billing doc -> fallback ke delivery_customer saja
        if ($validBillingDocument) {
            $key = $delivery . '_' . $validBillingDocument . '_' . $customerName;
        } else {
            $key = $delivery . '_' . $customerName;
        }
        
        $billingDate = $item['Billing Date'] ?? '';
        $billingDateParsed = null;
        $billingDateDisplay = '-';
        
        if (!empty($billingDate) && preg_match('/^\d{2}\.\d{2}\.\d{4}$/', $billingDate)) {
            try {
                $billingDateParsed = Carbon::createFromFormat('d.m.Y', $billingDate);
                $billingDateDisplay = $billingDateParsed->format('d M Y');
            } catch (\Exception $e) {
                Log::debug('Date parsing failed for: ' . $billingDate);
            }
        }
        
        // ✅ CREATE OR UPDATE GROUP
        if (!isset($grouped[$key])) {
            $grouped[$key] = [
                'delivery' => $delivery,
                'customer_name' => $customerName,
                'items' => [],
                'total_net_value' => 0,
                'billing_date' => $billingDate,
                'billing_date_parsed' => $billingDateParsed,
                'billing_date_display' => $billingDateDisplay,
                'billing_document' => $validBillingDocument,
                'booking_number' => trim($item['Booking Number'] ?? '') ?: null,
                'container_number' => trim($item['Container'] ?? $item['Container Number'] ?? '') ?: null,
                'currency' => $item['Currency'] ?? 'USD',
                'item_count' => 0,
                'status' => 'outstanding',
                'has_valid_billing' => !empty($validBillingDocument),
                'location' => $location,
                'created_at' => $item['Created Date'] ?? Carbon::now()->toDateTimeString(),
                'updated_at' => Carbon::now()->toDateTimeString(),
                'billing_documents' => [] // ✅ Array untuk track semua billing docs
            ];
            
            $processingStats['grouped_deliveries']++;
        }
        
        // ✅ SIMPLIFIED: Setiap entry sudah punya key dengan billing_document
        // Jadi billing_documents array hanya berisi 1 element = billing_document sendiri
        if (!empty($validBillingDocument)) {
            // ✅ Set single billing document, bukan accumulate
            $grouped[$key]['billing_documents'] = [$validBillingDocument];
            $grouped[$key]['billing_document'] = $validBillingDocument;
            $grouped[$key]['has_valid_billing'] = true;
        }
        
        // ✅ Add item to group
        $grouped[$key]['items'][] = $item;
        $grouped[$key]['item_count']++;
        
        // Calculate net value
        try {
            $netValueStr = $item['Net Value in Document Currency'] ?? '0';
            $netValue = floatval(str_replace([',', ' '], '', $netValueStr));
            $grouped[$key]['total_net_value'] += $netValue;
        } catch (\Exception $e) {
            Log::warning('Net value parsing error', [
                'delivery' => $delivery,
                'raw_value' => $item['Net Value in Document Currency'] ?? 'null',
                'error' => $e->getMessage()
            ]);
        }
        
        $processingStats['processed_records']++;
    }
    
    // ✅ DETECT entries dengan DO yang sama tapi billing berbeda (sibling entries)
    // Build map of delivery -> all billing docs
    $deliveryToBillings = [];
    foreach ($grouped as $key => $group) {
        $deliveryKey = $group['delivery'] . '_' . $group['customer_name'];
        if (!isset($deliveryToBillings[$deliveryKey])) {
            $deliveryToBillings[$deliveryKey] = [];
        }
        if (!empty($group['billing_document'])) {
            $deliveryToBillings[$deliveryKey][$key] = $group['billing_document'];
        }
    }
    
    // ✅ Mark entries yang punya sibling dengan billing berbeda
    $multipleCount = 0;
    foreach ($grouped as $key => &$group) {
        $deliveryKey = $group['delivery'] . '_' . $group['customer_name'];
        $allBillingsForDO = $deliveryToBillings[$deliveryKey] ?? [];
        
        if (count($allBillingsForDO) > 1) {
            $multipleCount++;
            $group['has_multiple_billing_documents'] = true;
            $group['sibling_billing_docs'] = array_values(array_filter($allBillingsForDO, function($b) use ($group) {
                return $b !== $group['billing_document'];
            }));
            $group['all_billing_docs_for_do'] = array_values($allBillingsForDO);
            
            Log::info('✅ DO WITH MULTIPLE BILLING ENTRIES', [
                'delivery' => $group['delivery'],
                'this_billing' => $group['billing_document'],
                'sibling_billings' => $group['sibling_billing_docs'],
                'customer' => $group['customer_name']
            ]);
        } else {
            $group['has_multiple_billing_documents'] = false;
            $group['sibling_billing_docs'] = [];
        }
    }
    unset($group);
    
    // ✅ ENHANCED LOGGING
    Log::info('GROUPING RESULTS - BILLING SEPARATION', [
        'total_records' => $processingStats['input_records'],
        'grouped_entries' => count($grouped),
        'entries_with_sibling_billing' => $multipleCount,
        'billing_prefixes_found' => $processingStats['billing_prefixes_found']
    ]);
    
    // ✅ Update status untuk setiap group
    foreach ($grouped as $key => &$group) {
        try {
            if (class_exists('App\Models\BillingStatus')) {
                $sapBillingData = [
                    'Billing Document' => $group['billing_document'],
                    'Delivery' => $group['delivery'],
                    'Customer Name' => $group['customer_name'],
                    'Booking Number' => $group['booking_number']
                ];
                
                $billingStatus = BillingStatus::updateStatus(
                    $group['delivery'], 
                    $group['customer_name'], 
                    null, 
                    false, 
                    $sapBillingData
                );
                
                $group['status'] = $billingStatus->status ?? 'outstanding';
                $group['billing_status_id'] = $billingStatus->id ?? null;
                
                $detailedProgress = BillingStatus::getDetailedProgress(
                    $group['delivery'], 
                    $group['customer_name']
                );
                $group['progress'] = $detailedProgress;
                $group['can_be_sent'] = $detailedProgress['can_be_sent'] ?? false;
                $group['next_action'] = $detailedProgress['next_action'] ?? 'Check documents';
            } else {
                $group['status'] = !empty($group['billing_document']) ? 'progress' : 'outstanding';
                $group['progress'] = null;
                $group['can_be_sent'] = false;
                $group['next_action'] = 'Manual status check required';
            }
            
        } catch (\Exception $e) {
            Log::error("Status calculation failed for {$group['delivery']}: " . $e->getMessage());
            $group['status'] = 'outstanding';
            $group['progress'] = null;
            $group['can_be_sent'] = false;
            $group['next_action'] = 'Error - please check manually';
        }
    }
    
    return $grouped;
}

