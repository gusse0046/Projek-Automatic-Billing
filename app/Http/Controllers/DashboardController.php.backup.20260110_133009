                'subject' => $subject,
                'billing_document' => $finalBillingDocument,
                'booking_number' => $bookingNumber
            ]);

            $emailData = [
                'delivery_order' => $deliveryOrder,
                'customer_name' => $customerName,
                'billing_document' => $finalBillingDocument,
                'booking_number' => $bookingNumber,
                'is_billing_email' => $finalBillingDocument && $finalBillingDocument !== $deliveryOrder,
                'subject' => $subject,
                'enhanced_subject' => $subject,
                'display_number' => $displayNumber,
                'email_message' => $emailMessage ?: $this->generateEnhancedEmailMessage(
